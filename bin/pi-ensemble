#!/usr/bin/env bash
#
# pi-ensemble — launch pi inside the sandboxed Docker container.
#
# The container fence IS the trust boundary: inside, all permission gating is
# disabled (PI_ENSEMBLE_SANDBOX_MODE=1) so the user is never prompted for a
# tool call. Host state that should survive across sessions is bind-mounted:
#
#   - $HOME/.vipune/                       → /home/vscode/.vipune
#       (cross-session project memory; preserves your accumulated vipune store)
#   - $HOME/.pi/agent/ensemble-runs/       → /home/vscode/.pi/agent/ensemble-runs
#       (transcripts; /runs browses these in both host AND sandbox sessions)
#   - $HOME/.pi/agent/sessions/            → /home/vscode/.pi/agent/sessions
#       (Pi conversation sessions; `pi-ensemble -r` finds previous sandbox
#        sessions for the same project. NOTE: Pi scopes sessions by absolute
#        project path, so host-mode `pi -r` sessions live in a DIFFERENT
#        sub-bucket from sandbox-mode `pi-ensemble -r` sessions — they
#        don't cross-resume, even with this bind-mount.)
#   - $HOME/.pi/agent/ensemble-models.json → same path inside container
#       (per-role subagent model picks)
#   - $HOME/.config/mcp/mcp.json           → same path inside container (RO)
#       (host install.sh writes this; codebase-memory-mcp wiring lives here)
#   - $HOME/.config/gh/                    → same path inside container (RO)
#       (gh auth — alternative is to pass GH_TOKEN env)
#
# Caches (codebase-memory-mcp index, ~/.bun, ~/.cargo, shell history) live in
# named volumes (`pi-ensemble-cache`, `pi-ensemble-bun-cache`, etc.) shared
# across projects.
#
# Subcommands:
#   (none)        Interactive `pi` session in the container (default)
#   -r, --resume  Pass through to `pi -r` — resume a previous sandbox
#                 session for this project. Forwarded as a flag, not a
#                 subcommand.
#   shell         Drop into bash inside the container
#   rebuild       Rebuild the pi-ensemble image
#   stop          Stop the running container for this project
#   prune         Remove named volumes (DESTROYS sandbox caches — vipune/runs/
#                 sessions stay safe because they're bind-mounted from host)
#   logs          Tail container logs
#   status        Show whether a container is running for this project
#   --help        Show this help

set -euo pipefail

IMAGE="${PI_ENSEMBLE_IMAGE:-ghcr.io/randomm/pi-ensemble:latest}"
PROJECT_ROOT="$(cd "$(pwd)" && pwd -P)"
PROJECT_NAME="$(basename "$PROJECT_ROOT" | tr -c 'A-Za-z0-9._-' '-' | head -c 40)"
# Project-hash so concurrent `pi-ensemble` calls in DIFFERENT projects get
# distinct container-name prefixes. Same-project concurrency relies on the
# RUN_SUFFIX below, not this hash.
PROJECT_HASH="$(printf '%s' "$PROJECT_ROOT" | shasum -a 256 | cut -c1-12)"
# BASE_NAME identifies the project; CONTAINER_NAME identifies the specific
# `pi-ensemble` invocation. The RUN_SUFFIX lets two terminals open sessions
# in the same project without colliding on the docker --name flag. The
# stop/status/logs subcommands enumerate `${BASE_NAME}-*` to find sessions.
BASE_NAME="pi-ensemble-${PROJECT_NAME}-${PROJECT_HASH}"
RUN_SUFFIX="$(head -c 4 /dev/urandom | xxd -p)"
CONTAINER_NAME="${BASE_NAME}-${RUN_SUFFIX}"

usage() {
  sed -n '/^#$/,/^$/p' "$0" | grep -E '^#' | sed 's/^# \{0,1\}//'
  exit 0
}

require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    cat >&2 <<EOF
!! Docker not found on PATH.
   pi-ensemble (sandbox mode) needs Docker Desktop, Colima, or another
   docker-compatible runtime. Install one of:
     - Docker Desktop  https://docker.com
     - Colima (macOS)  brew install colima && colima start
     - OrbStack (macOS, paid)  https://orbstack.dev
   Alternatively, use host-mode \`pi\` directly (with the legacy permission
   system).
EOF
    exit 2
  fi
  if ! docker info >/dev/null 2>&1; then
    echo "!! Docker is installed but the daemon isn't running. Start Docker and retry." >&2
    exit 2
  fi
}

ensure_image() {
  if docker image inspect "$IMAGE" >/dev/null 2>&1; then
    return  # already cached locally
  fi
  # Prefer pull from the registry (GHCR auto-publishes on every merge to main
  # via .github/workflows/publish-image.yml). Fall back to local build for
  # offline / unpublished-image / dev scenarios — no regression for users
  # actively iterating on the Dockerfile.
  echo "==> Image $IMAGE not present locally. Pulling from registry..."
  if docker pull "$IMAGE"; then
    return
  fi
  echo "==> Pull failed. Falling back to local build from pi-ensemble repo..."
  local repo_dir
  repo_dir="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || python3 -c 'import os,sys;print(os.path.realpath(sys.argv[1]))' "$0")")/.." && pwd)"
  docker build -t "$IMAGE" -f "$repo_dir/.devcontainer/Dockerfile" "$repo_dir"
}

build_mounts() {
  # bash arrays via stdout — caller eval's. This is the cleanest way to assemble
  # conditional -v flags without losing word boundaries.
  #
  # Design principle: the sandbox MUST NOT require the host to have
  # pi-ensemble's toolchain installed. Docker is the only host prereq.
  # Where the host happens to have existing state (vipune memories,
  # ensemble-runs transcripts, etc.) we bind-mount it through to
  # preserve continuity. Where the host has nothing, we fall back to
  # named volumes so the container still gets persistent state across
  # runs (just container-scoped instead of shared with host).
  local mounts=()
  # Mount the project at its HOST ABSOLUTE PATH inside the container, not at
  # /workspace. Why: Pi scopes sessions by absolute cwd, so a project at
  # /Users/janni/projects/nessie running in host mode and the same project
  # running in sandbox mode must share cwd to share the same sessions/<scope>
  # bucket. Pre-#207 we mounted at /workspace and Pi inside the container
  # cwd'd there, sending sandbox sessions for ALL projects into a single
  # co-mingled `--workspace--` bucket — which broke `pi-ensemble -r`
  # entirely (couldn't tell which session belonged to which project).
  # Post-#207: host cwd == container cwd → session buckets match,
  # per-project isolation restored, host↔sandbox cross-resume works.
  mounts+=(-v "$PROJECT_ROOT:$PROJECT_ROOT:delegated")

  # vipune — host bind-mount if present (preserves accumulated memories);
  # else named volume (persists across container runs).
  if [ -d "$HOME/.vipune" ]; then
    mounts+=(-v "$HOME/.vipune:/home/vscode/.vipune")
  else
    mounts+=(-v pi-ensemble-vipune:/home/vscode/.vipune)
  fi

  # ensemble-runs transcripts — same pattern. /runs slash command browses
  # these, so persisting them across container restarts is the user
  # expectation regardless of host state.
  if [ -d "$HOME/.pi/agent/ensemble-runs" ]; then
    mounts+=(-v "$HOME/.pi/agent/ensemble-runs:/home/vscode/.pi/agent/ensemble-runs")
  else
    mounts+=(-v pi-ensemble-runs:/home/vscode/.pi/agent/ensemble-runs)
  fi

  # Pi sessions — `pi -r` reads these for resume. Bind-mount the host's
  # sessions dir if it exists; else use a named volume so container
  # sessions persist across container restarts. NOTE: Pi scopes sessions
  # by absolute project path, and the same project mounts at /workspace
  # inside the container vs. ~/projects/foo on the host — so host and
  # sandbox sessions live in DIFFERENT sub-buckets and don't cross-
  # resume. Within sandbox: `pi-ensemble -r` finds previous pi-ensemble
  # sessions for the same project. Within host: `pi -r` finds previous
  # host-mode sessions. Crossing modes is out of scope.
  if [ -d "$HOME/.pi/agent/sessions" ]; then
    mounts+=(-v "$HOME/.pi/agent/sessions:/home/vscode/.pi/agent/sessions")
  else
    mounts+=(-v pi-ensemble-sessions:/home/vscode/.pi/agent/sessions)
  fi

  # ensemble-models.json — pi-ensemble's per-role model picks. Bound RW
  # (not :ro) so /ensemble-model inside the sandbox can update picks and
  # those updates persist back to the host's ~/.pi/agent/ensemble-models.json
  # (symmetric with the sessions/ bind from PR #206). Only bind if present
  # on host; otherwise the container uses its own (defaults) and won't write.
  if [ -f "$HOME/.pi/agent/ensemble-models.json" ]; then
    mounts+=(-v "$HOME/.pi/agent/ensemble-models.json:/home/vscode/.pi/agent/ensemble-models.json")
  fi

  # models.json — Pi's PROVIDER config (custom OpenAI-compatible endpoints
  # like trailopeners-h100, halo, etc.). Without this bind, the container
  # sees only Pi's built-in providers (anthropic, openai) — any custom
  # provider the user added on host is invisible inside the sandbox.
  # See PR #205 (regression fix). API keys interpolated from env vars
  # (e.g. trailopeners' "apiKey": "$TRAIL_OPENERS_LLM_KEY") rely on the
  # extended env-passthrough in build_env to surface those vars.
  if [ -f "$HOME/.pi/agent/models.json" ]; then
    mounts+=(-v "$HOME/.pi/agent/models.json:/home/vscode/.pi/agent/models.json:ro")
  fi

  # mcp.json — bind-mount if present; PR #202 made entries PATH-portable
  # so the same file works in both host and container contexts. If the
  # host doesn't have one, the container's baked default (with
  # codebase_memory wired) takes over.
  if [ -f "$HOME/.config/mcp/mcp.json" ]; then
    mounts+=(-v "$HOME/.config/mcp/mcp.json:/home/vscode/.config/mcp/mcp.json:ro")
  fi

  # gh auth — bind-mount as fallback. The primary auth channel is the
  # GH_TOKEN env var (extracted via `gh auth token` on host; see
  # build_env). gh inside the container honors GH_TOKEN first; the
  # bind-mount is a belt-and-braces option for installations that
  # configured gh without a token (e.g. SSO web flow only).
  if [ -d "$HOME/.config/gh" ]; then
    mounts+=(-v "$HOME/.config/gh:/home/vscode/.config/gh:ro")
  fi

  # Image directories — for drag-and-drop into Pi via @file syntax. Bind-
  # mounted READ-ONLY at the host's absolute paths so a path pasted by the
  # terminal (e.g. /Users/you/Downloads/screenshot.png) resolves inside.
  # sandbox-fs-guard is also told about these via PI_ENSEMBLE_ALLOWED_ROOTS
  # so the read tool doesn't block paths outside the project workspace.
  # Default: $HOME/Downloads, $HOME/Desktop, $HOME/Pictures. Override via
  # PI_ENSEMBLE_IMAGE_DIRS="dir1:dir2" (colon-separated, replaces default).
  # Extend via PI_ENSEMBLE_EXTRA_IMAGE_DIRS="dir1:dir2" (appends).
  local default_image_dirs="$HOME/Downloads:$HOME/Desktop:$HOME/Pictures"
  local image_dirs_raw="${PI_ENSEMBLE_IMAGE_DIRS:-$default_image_dirs}"
  if [ -n "${PI_ENSEMBLE_EXTRA_IMAGE_DIRS-}" ]; then
    image_dirs_raw="${image_dirs_raw}:${PI_ENSEMBLE_EXTRA_IMAGE_DIRS}"
  fi
  IFS=':' read -ra image_dirs <<<"$image_dirs_raw"
  for dir in "${image_dirs[@]}"; do
    [ -z "$dir" ] && continue
    [ -d "$dir" ] || continue
    mounts+=(-v "$dir:$dir:ro")
  done

  # Host docker socket — bind-mounted by default if Docker is running on
  # the host, so docker-based MCP servers in .pi/mcp.json work transparently
  # (the CLI inside the sandbox talks to the HOST docker daemon; spawned
  # MCPs are SIBLING containers, visible in the host's `docker ps`). Opt
  # out with PI_ENSEMBLE_NO_DOCKER_SOCKET=1 if you want the tighter sandbox.
  # SECURITY: the docker socket grants root-equivalent host access from
  # inside the sandbox, weakening the container fence. Consistent with the
  # trust-mode philosophy from #215: pi-ensemble's container is the agent's
  # runtime, not a meaningful security boundary — the user is the trust
  # authority. See AGENTS.md "Permission model" section.
  if [ "${PI_ENSEMBLE_NO_DOCKER_SOCKET-}" = "1" ]; then
    :  # explicit opt-out — keep the tighter sandbox
  elif [ -S /var/run/docker.sock ]; then
    mounts+=(-v "/var/run/docker.sock:/var/run/docker.sock")
  fi

  # SSH credentials — bind-mount ~/.ssh/ read-only AND forward the host's
  # SSH_AUTH_SOCK (if set) so `ssh remote-host` inside the sandbox uses the
  # same identities as host-mode pi. Mirrors the docker-socket transparency:
  # the user shouldn't need a flag to make ssh work the way it does on host.
  # Opt out with PI_ENSEMBLE_NO_SSH=1.
  #
  # RO mount means: known_hosts updates from inside the sandbox don't persist
  # to host (acceptable trade-off — fresh host-key entries can be added on
  # the host with `ssh -o StrictHostKeyChecking=accept-new ...`). Keys with
  # strict file perms still work because the agent socket sidesteps file IO
  # when SSH_AUTH_SOCK is set; if you have on-disk keys only (no agent), the
  # UID mismatch between host (501 on macOS) and vscode (1000) may cause
  # SSH's StrictModes to refuse them — workaround: start an ssh-agent on
  # host (`eval $(ssh-agent) && ssh-add <key>`) before launching pi-ensemble.
  if [ "${PI_ENSEMBLE_NO_SSH-}" = "1" ]; then
    :
  else
    if [ -d "$HOME/.ssh" ]; then
      mounts+=(-v "$HOME/.ssh:/home/vscode/.ssh:ro")
    fi
    if [ -n "${SSH_AUTH_SOCK-}" ] && [ -S "${SSH_AUTH_SOCK}" ]; then
      mounts+=(-v "${SSH_AUTH_SOCK}:/run/host-ssh-auth.sock")
    fi
  fi

  # Named volumes (caches, shell history) — shared across all projects
  # using the same image, container-scoped, NOT bind-mounted from host.
  mounts+=(-v pi-ensemble-cache:/home/vscode/.cache)
  mounts+=(-v pi-ensemble-bun-cache:/home/vscode/.bun)
  mounts+=(-v pi-ensemble-cargo-cache:/home/vscode/.cargo)
  mounts+=(-v pi-ensemble-history:/commandhistory)
  printf '%s\n' "${mounts[@]}"
}

build_env() {
  # Env passthrough — two layers:
  #
  # 1. Pattern-based auto-forward: anything matching *_API_KEY or *_LLM_KEY
  #    in the host shell. Catches custom provider tokens like
  #    TRAIL_OPENERS_LLM_KEY without needing to enumerate every provider
  #    by name. Pi's models.json `apiKey: "$VAR"` syntax depends on these
  #    env vars existing inside the container.
  #
  # 2. Explicit list: well-known vars we always forward if set
  #    (Anthropic / OpenAI / Cerebras / Parallel / Groq / Gemini /
  #    OpenRouter / DeepSeek / xAI plus GH/GITHUB tokens).
  #
  # 3. User-override: PI_ENSEMBLE_EXTRA_ENV="VAR1,VAR2" lets the user
  #    forward arbitrary extra vars.
  #
  # Deduplication: track forwarded names so the same var doesn't get forwarded
  # twice if it matches both a pattern AND the explicit list.
  local envs=()
  local seen_names=" "
  local explicit=(
    ANTHROPIC_API_KEY
    CEREBRAS_API_KEY
    PARALLEL_API_KEY
    OPENAI_API_KEY
    GROQ_API_KEY
    GOOGLE_API_KEY
    GEMINI_API_KEY
    OPENROUTER_API_KEY
    DEEPSEEK_API_KEY
    XAI_API_KEY
    MISTRAL_API_KEY
    TOGETHER_API_KEY
    COHERE_API_KEY
    GH_TOKEN
    GITHUB_TOKEN
  )
  # Pattern-based auto-forward
  while IFS='=' read -r var _; do
    [[ -z "$var" ]] && continue
    case "$var" in
      *_API_KEY|*_LLM_KEY)
        if [ -n "${!var-}" ] && [[ "$seen_names" != *" $var "* ]]; then
          envs+=(-e "$var=${!var}")
          seen_names+="$var "
        fi
        ;;
    esac
  done < <(env)
  # Explicit list (covers vars not matching the patterns above)
  for var in "${explicit[@]}"; do
    if [ -n "${!var-}" ] && [[ "$seen_names" != *" $var "* ]]; then
      envs+=(-e "$var=${!var}")
      seen_names+="$var "
    fi
  done
  # User override: PI_ENSEMBLE_EXTRA_ENV="VAR1,VAR2,VAR3"
  if [ -n "${PI_ENSEMBLE_EXTRA_ENV-}" ]; then
    IFS=',' read -ra extra <<<"$PI_ENSEMBLE_EXTRA_ENV"
    for var in "${extra[@]}"; do
      var="${var// /}"  # strip whitespace
      [ -z "$var" ] && continue
      if [ -n "${!var-}" ] && [[ "$seen_names" != *" $var "* ]]; then
        envs+=(-e "$var=${!var}")
        seen_names+="$var "
      fi
    done
  fi

  # gh auth: if the user has gh installed and authenticated on host, extract
  # the token and forward as GH_TOKEN. This handles the common macOS case
  # where `gh auth login` stores the token in Keychain (not on disk at
  # ~/.config/gh/hosts.yml), making the bind-mount-alone strategy
  # insufficient. `gh auth token` works regardless of where the token
  # lives. Skip silently if gh isn't installed or no token is configured —
  # user can `gh auth login -h github.com` inside the container in that case.
  if [ -z "${GH_TOKEN-}" ] && [ -z "${GITHUB_TOKEN-}" ] && command -v gh >/dev/null 2>&1; then
    if gh_tok="$(gh auth token 2>/dev/null)" && [ -n "$gh_tok" ]; then
      envs+=(-e "GH_TOKEN=$gh_tok")
    fi
  fi
  # SSH agent forwarding — if the host has an agent running AND ssh isn't
  # explicitly opted out via PI_ENSEMBLE_NO_SSH=1, point the container's
  # SSH_AUTH_SOCK at the bind-mounted host socket (see build_mounts).
  if [ "${PI_ENSEMBLE_NO_SSH-}" != "1" ] && [ -n "${SSH_AUTH_SOCK-}" ] && [ -S "${SSH_AUTH_SOCK}" ]; then
    envs+=(-e "SSH_AUTH_SOCK=/run/host-ssh-auth.sock")
  fi

  # Container-only flags
  envs+=(-e PI_ENSEMBLE_SANDBOX_MODE=1)
  # Workspace root — used by sandbox-fs-guard to enforce the FS boundary.
  # Set to PROJECT_ROOT (the host absolute path mounted in by build_mounts)
  # so the guard's "outside the workspace" check works for the new mount
  # shape (#207 — was hard-coded /workspace).
  envs+=(-e "PI_ENSEMBLE_WORKSPACE_ROOT=$PROJECT_ROOT")
  # Additional allowed roots — sandbox-fs-guard treats paths under these as
  # in-bounds in addition to the workspace root. Wrapper sets this to the
  # same list of image-dirs build_mounts bind-mounts, so drag-and-dropped
  # images from $HOME/Downloads etc. work without blanket-allowing all FS
  # access. Mirrors PI_ENSEMBLE_IMAGE_DIRS / EXTRA_IMAGE_DIRS so the
  # mount-list and guard-allow-list stay in sync.
  local default_image_dirs="$HOME/Downloads:$HOME/Desktop:$HOME/Pictures"
  local guard_roots="${PI_ENSEMBLE_IMAGE_DIRS:-$default_image_dirs}"
  if [ -n "${PI_ENSEMBLE_EXTRA_IMAGE_DIRS-}" ]; then
    guard_roots="${guard_roots}:${PI_ENSEMBLE_EXTRA_IMAGE_DIRS}"
  fi
  # Filter to existing dirs only (extant_dirs preserves order, skips missing)
  local extant_dirs=""
  IFS=':' read -ra dir_list <<<"$guard_roots"
  for dir in "${dir_list[@]}"; do
    [ -z "$dir" ] && continue
    [ -d "$dir" ] || continue
    extant_dirs="${extant_dirs:+$extant_dirs:}$dir"
  done
  if [ -n "$extant_dirs" ]; then
    envs+=(-e "PI_ENSEMBLE_ALLOWED_ROOTS=$extant_dirs")
  fi
  envs+=(-e "HISTFILE=/commandhistory/.bash_history")
  printf '%s\n' "${envs[@]}"
}

build_host_aliases() {
  # Hostnames that exist on the host's network (Tailscale MagicDNS, LAN, /etc/hosts)
  # but won't resolve inside the container. Use `--add-host name:ip` to teach the
  # container's resolver. List is colon-separated `name:ip` pairs in
  # $PI_ENSEMBLE_HOST_ALIASES (env), with one well-known default:
  #
  #   PI_ENSEMBLE_HOST_ALIASES="halo:192.168.8.249,myserver:10.0.0.7"
  #
  # The default below registers `halo` (the LLM gateway documented in your
  # ~/.pi/agent/models.json). Override the env to add more or change the IP.
  local aliases=()
  local default_aliases="halo:192.168.8.249"
  local raw="${PI_ENSEMBLE_HOST_ALIASES:-$default_aliases}"
  IFS=',' read -ra pairs <<<"$raw"
  for pair in "${pairs[@]}"; do
    [ -z "$pair" ] && continue
    aliases+=(--add-host="$pair")
  done
  printf '%s\n' "${aliases[@]}"
}

run_container() {
  local cmd=("$@")
  local mounts=()
  local envs=()
  local hosts=()
  local line
  while IFS= read -r line; do mounts+=("$line"); done < <(build_mounts)
  while IFS= read -r line; do envs+=("$line"); done < <(build_env)
  while IFS= read -r line; do hosts+=("$line"); done < <(build_host_aliases)
  docker run --rm -it \
    --name "$CONTAINER_NAME" \
    -w "$PROJECT_ROOT" \
    "${mounts[@]}" \
    "${envs[@]}" \
    "${hosts[@]}" \
    "$IMAGE" \
    "${cmd[@]}"
}

cmd_default() {
  require_docker
  ensure_image
  run_container pi "$@"
}

cmd_shell() {
  require_docker
  ensure_image
  run_container bash
}

cmd_rebuild() {
  require_docker
  local repo_dir
  repo_dir="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || python3 -c 'import os,sys;print(os.path.realpath(sys.argv[1]))' "$0")")/.." && pwd)"
  docker build -t "$IMAGE" -f "$repo_dir/.devcontainer/Dockerfile" "$repo_dir"
}

cmd_stop() {
  require_docker
  local matches
  matches="$(docker ps --format '{{.Names}}' | grep -E "^${BASE_NAME}-" || true)"
  if [ -z "$matches" ]; then
    echo "No running pi-ensemble container for $PROJECT_ROOT"
    return
  fi
  local count
  count=$(printf '%s\n' "$matches" | wc -l | tr -d ' ')
  echo "Stopping $count pi-ensemble container(s) for $PROJECT_ROOT:"
  printf '%s\n' "$matches" | while IFS= read -r name; do
    docker stop "$name"
  done
}

cmd_prune() {
  require_docker
  echo "This removes shared sandbox caches (codebase-memory-mcp index,"
  echo "bun/cargo caches, shell history). Bind-mounted host state"
  echo "(vipune, transcripts, model picks) is NOT affected."
  read -r -p "Continue? [y/N] " ans
  case "$ans" in
    y|Y|yes) ;;
    *) echo "Cancelled"; exit 0 ;;
  esac
  for vol in pi-ensemble-cache pi-ensemble-bun-cache pi-ensemble-cargo-cache pi-ensemble-history; do
    docker volume rm "$vol" 2>/dev/null && echo "removed $vol" || echo "skip $vol (not present or in use)"
  done
}

cmd_logs() {
  require_docker
  local matches count
  matches="$(docker ps --format '{{.Names}}' | grep -E "^${BASE_NAME}-" || true)"
  count=$(printf '%s' "$matches" | grep -c . || true)
  if [ "$count" -eq 0 ]; then
    echo "No running pi-ensemble container for $PROJECT_ROOT" >&2
    exit 1
  fi
  if [ "$count" -eq 1 ]; then
    docker logs -f "$matches"
    return
  fi
  echo "Multiple pi-ensemble containers running for $PROJECT_ROOT:" >&2
  printf '%s\n' "$matches" | sed 's/^/  /' >&2
  echo "Specify one: docker logs -f <name>" >&2
  exit 1
}

cmd_status() {
  require_docker
  local matches
  matches="$(docker ps --format '{{.Names}}\t{{.Status}}' | grep -E "^${BASE_NAME}-" || true)"
  if [ -z "$matches" ]; then
    echo "No running pi-ensemble container for $PROJECT_ROOT"
    return
  fi
  printf 'NAMES\tSTATUS\n%s\n' "$matches"
}

# ----- dispatch -----
case "${1:-}" in
  ""|--)        shift || true; cmd_default "$@" ;;
  shell)        cmd_shell ;;
  rebuild)      cmd_rebuild ;;
  stop)         cmd_stop ;;
  prune)        cmd_prune ;;
  logs)         cmd_logs ;;
  status)       cmd_status ;;
  -h|--help|help) usage ;;
  *)            cmd_default "$@" ;;
esac
