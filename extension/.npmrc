# Supply-chain defence for npm / pnpm / yarn users — mirrors bunfig.toml's
# `minimumReleaseAge` setting.
#
# - npm 11.10.0+ honors `min-release-age` (days)
# - pnpm 9.0+ honors the same key
# - older clients silently ignore it
#
# Keep this in sync with the seconds value in bunfig.toml.

min-release-age=4

# Refuse to install when the runtime doesn't satisfy `engines` in package.json.
# Forces npm/pnpm users onto a version new enough to enforce min-release-age.
engine-strict=true
