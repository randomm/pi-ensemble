{
  "name": "@randomm/pi-ensemble",
  "version": "0.12.4",
  "description": "Multi-specialist orchestrator extension for Pi — parallel worktree-isolated dispatch, adversarial gate, six-pass code review.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "ai-agent",
    "multi-agent",
    "code-review",
    "orchestrator"
  ],
  "license": "Apache-2.0",
  "author": "Janni Turunen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/randomm/pi-ensemble.git",
    "directory": "extension"
  },
  "bugs": {
    "url": "https://github.com/randomm/pi-ensemble/issues"
  },
  "homepage": "https://github.com/randomm/pi-ensemble#readme",
  "type": "module",
  "main": "src/index.ts",
  "engines": {
    "bun": ">=1.2.20",
    "npm": ">=11.10.0"
  },
  "scripts": {
    "check": "biome check src/",
    "format": "biome format --write src/",
