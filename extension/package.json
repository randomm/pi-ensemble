  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@earendil-works/pi-coding-agent": "~0.75.3",
    "@earendil-works/pi-tui": "~0.75.3",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
